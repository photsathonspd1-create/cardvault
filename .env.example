# ═══════════════════════════════════════
# CardVault Environment Variables
# Copy to .env.local and fill in values
# ═══════════════════════════════════════

# Database (Supabase / any PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/cardvault

# NextAuth
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
NEXTAUTH_URL=https://cardvault.co.th

# LINE Login (optional — skip if not using LINE)
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=

# Omise Payment
OMISE_PUBLIC_KEY=pkey_test_xxx
OMISE_SECRET_KEY=skey_test_xxx
OMISE_WEBHOOK_SECRET=

# Cloudflare R2 (image storage)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cardvault-assets
R2_PUBLIC_URL=https://assets.cardvault.co.th

# Upstash Redis (rate limiting — optional, falls back to in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (email notifications)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=CardVault <noreply@cardvault.co.th>

# Pokemon TCG API (optional — for card identification)
POKEMON_TCG_API_KEY=

# App
NEXT_PUBLIC_APP_URL=https://cardvault.co.th
PLATFORM_FEE_PERCENT=6
ESCROW_AUTO_RELEASE_DAYS=7
